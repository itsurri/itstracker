rules_version = '2';

// Regole di sicurezza Firestore complete per itstracker.
// Copre TUTTE le collection usate dall'app (anche quelle vecchie: comments,
// notifications, publicProfiles, chats). Sostituisci l'intero contenuto delle
// regole nella console Firebase (Firestore Database > Regole) con questo file,
// poi premi "Pubblica".

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Profilo privato + sync libreria: solo il proprietario ----
    // Contiene library, filmLibrary, tmdbKey, nickname, customPhotoURL,
    // following, coverImage. Nessun altro utente deve poterlo leggere.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ---- Profili pubblici: lettura libera, scrittura solo del proprietario ----
    // Usati per ricerca persone, menzioni @, feed e scheda profilo pubblica.
    // Eccezione: chi segue/smette di seguire questo utente può aggiornare
    // SOLO il campo "followers" (tramite arrayUnion/arrayRemove del proprio uid).
    match /publicProfiles/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']);
    }

    // ---- Commenti agli episodi ----
    // Lettura libera (i conteggi si vedono anche senza login).
    // Creazione: solo autenticato e come sé stesso.
    // Update: chiunque può mettere/togliere like (solo campo likedBy); l'autore
    //         del commento può anche aggiornare il proprio badge di livello
    //         (authorLevel/authorLevelEmoji), usato per il backfill dei commenti
    //         vecchi postati prima che il sistema di livelli esistesse.
    // Delete: l'autore del commento, oppure l'autore del commento padre
    //         (per l'eliminazione a cascata delle risposte).
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.epKey is string
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 500;
      allow update: if request.auth != null && (
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy'])
                       || (resource.data.uid == request.auth.uid
                           && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authorLevel', 'authorLevelEmoji']))
                    );
      allow delete: if request.auth != null && (
                       resource.data.uid == request.auth.uid
                       || (resource.data.parentId != null
                           && get(/databases/$(database)/documents/comments/$(resource.data.parentId)).data.uid == request.auth.uid)
                    );
    }

    // ---- Reazioni rapide agli episodi ----
    // Lettura libera (per mostrare i conteggi), scrittura per utenti autenticati
    // (ognuno aggiunge/rimuove solo il proprio uid tramite arrayUnion/arrayRemove).
    // Nota: non potendo validare qui il contenuto della map annidata "reactions",
    // richiediamo almeno che l'epKey dichiarato combaci con l'id del documento.
    match /reactions/{epKey} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.data.epKey == epKey;
    }

    // ---- Notifiche ----
    // Le legge, segna come lette ed elimina solo il destinatario.
    // Chiunque autenticato può crearne una (like, risposta, menzione, messaggio),
    // ma solo con un tipo previsto, testo limitato e non verso sé stessi.
    match /notifications/{notifId} {
      allow read, update, delete: if request.auth != null
                                  && resource.data.toUid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.toUid is string
                    && request.resource.data.toUid != request.auth.uid
                    && request.resource.data.type in ['message', 'like', 'reply', 'mention', 'follow']
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 300;
    }

    // ---- Feed attività ----
    // Lettura libera (feed di chi si segue). Creazione solo come sé stesso.
    match /activity/{actId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.uid == request.auth.uid;
    }

    // ---- Chat 1:1 ----
    // Il documento chat va letto sia per ID noto (apertura di una chat)
    // sia tramite la query .where('participants','array-contains', uid)
    // usata dalla lista conversazioni: per una query di questo tipo Firestore
    // richiede che la regola sia basata sul campo "participants" stesso,
    // non sull'id del documento, altrimenti rifiuta l'intera query con
    // permission-denied anche se i singoli documenti sarebbero validi.
    match /chats/{chatId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;

      // Le sotto-collection "messages" sono sempre lette/scritte tramite un
      // chatId noto (mai in query aperta su più chat), quindi qui la verifica
      // sull'id del documento resta corretta e non soffre della limitazione
      // sopra.
      match /messages/{msgId} {
        allow read: if request.auth != null
                    && request.auth.uid in chatId.split('_');
        allow create: if request.auth != null
                      && request.auth.uid in chatId.split('_')
                      && request.resource.data.from == request.auth.uid;
      }
    }
  }
}
